# yc-voice-agent-hackathon - Environment Variables
# Copy this file to .env and fill in your API keys

# Twilio (Transport)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gradium (TTS)
GRADIUM_API_KEY=
GRADIUM_VOICE_ID=

# Gemini (LLM)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_THINKING_BUDGET=0

# NVIDIA Nemotron ASR (STT)
NVIDIA_ASR_URL=

# NVIDIA Nemotron LLM
NEMOTRON_LLM_URL=
NEMOTRON_LLM_MODEL=nvidia/nemotron-3-super
NEMOTRON_ENABLE_THINKING=

# Cekura (evals and MCP)
CEKURA_API_KEY=
CEKURA_AGENT_ID=
CEKURA_SCENARIO_IDS=
